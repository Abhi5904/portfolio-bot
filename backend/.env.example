# ── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/DBNAME?schema=public
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=YOUR_DB_USER
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_DB=YOUR_DB_NAME

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ── CORS ───────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL in production (do NOT use * with credentials)
# Multiple origins: CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
CORS_ORIGIN=https://your-app.vercel.app
CORS_CREDENTIALS=true

# ── Bull Board ─────────────────────────────────────────────────────────────
BULL_BOARD_PATH=/admin/queues
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=YOUR_BULL_BOARD_PASSWORD

# ── Auth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET
ADMIN_EMAIL=admin@example.com

# ── Ollama ─────────────────────────────────────────────────────────────────
# Use host.docker.internal when Ollama runs on the EC2 host (outside Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET
