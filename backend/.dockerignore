# ── Node dependencies (reinstalled inside the image) ──────────────────────
node_modules
npm-debug.log
yarn-error.log
pnpm-debug.log

# ── Build output (rebuilt inside the image) ───────────────────────────────
dist
build
coverage

# ── Environment files (injected at runtime via env_file / -e) ─────────────
.env
.env.*
!.env.example

# ── Git metadata ───────────────────────────────────────────────────────────
.git
.gitignore

# ── Docker files (don't copy into the image they're building) ─────────────
Dockerfile
docker-compose*.yml

# ── Logs ───────────────────────────────────────────────────────────────────
logs
*.log

# ── Editor / OS artefacts ──────────────────────────────────────────────────
.vscode
.idea
.DS_Store
*.swp

# ── Tests ──────────────────────────────────────────────────────────────────
__tests__
*.spec.ts
*.test.ts

# ── Cache / temp ───────────────────────────────────────────────────────────
.tmp
.cache

# ── Docs ───────────────────────────────────────────────────────────────────
*.md
